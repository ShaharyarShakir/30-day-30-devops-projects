# --- PostgreSQL ---
POSTGRES_DB=chaindeploy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/chaindeploy

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_MGMT_PORT=15672

# --- Vault (dev mode only — NEVER use dev mode in production) ---
VAULT_DEV_ROOT_TOKEN_ID=root
VAULT_ADDR=http://vault:8200
VAULT_PORT=8200

# --- Auth (Sprint 2) ---
JWT_SECRET=change-me-in-sprint-2
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_TTL=7d
GITHUB_OAUTH_CLIENT_ID=dummy-client-id
GITHUB_OAUTH_CLIENT_SECRET=dummy-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# --- Service ports (Sprints 2-4) ---
API_PORT=3000
