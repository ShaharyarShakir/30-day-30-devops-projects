# Django
SECRET_KEY=django-insecure-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=media_service
DB_USER=postgres
DB_PASSWORD=postgres

# S3/Garage
S3_ENDPOINT_URL=http://localhost:3900
S3_ACCESS_KEY=garage
S3_SECRET_KEY=garage
S3_BUCKET=media
S3_REGION=us-east-1

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_UPLOAD_COMPLETED=media.upload.completed

# Upload
MAX_UPLOAD_SIZE=21474836480
UPLOAD_SESSION_EXPIRY_HOURS=24

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
