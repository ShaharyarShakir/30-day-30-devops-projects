{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserUpdatedEvent",
  "type": "object",
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "enum": ["user.updated"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "format": "uuid"
        },
        "displayName": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": ["userId", "displayName"]
    }
  },
  "required": ["eventId", "eventType", "timestamp", "data"]
}
