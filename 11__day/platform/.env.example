# Platform Global Environment Configuration

# Core Infrastructure Hosts
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=redis
MONGO_HOST=mongodb
KAFKA_BROKER=kafka:9092
GARAGE_ENDPOINT=http://garage:3900

SMTP_HOST=mailpit
SMTP_PORT=1025

# Service Ports & Hostnames (Internal Docker / External Local)
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8080
FRONTEND_PORT=3000

# Auth JWT Secret
JWT_SECRET=super_secret_platform_dev_jwt_key_that_is_at_least_256_bits_long_for_security_standards
JWT_EXPIRATION_MS=86400000

# Logging Level
LOG_LEVEL=info
