      "id": 1,
      "title": "Prediction Throughput (TPS)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(kserve_predictor_request_duration_seconds_count{inferenceservice=\"candidate-ranker\"}[1m])) by (inferenceservice)",
          "legendFormat": "{{inferenceservice}} TPS",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "reqps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "title": "Model Prediction Latency (P50, P95, P99)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(kserve_predictor_request_duration_seconds_bucket{inferenceservice=\"candidate-ranker\"}[5m])) by (le))",
          "legendFormat": "P50 Latency",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(kserve_predictor_request_duration_seconds_bucket{inferenceservice=\"candidate-ranker\"}[5m])) by (le))",
          "legendFormat": "P95 Latency",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(kserve_predictor_request_duration_seconds_bucket{inferenceservice=\"candidate-ranker\"}[5m])) by (le))",
          "legendFormat": "P99 Latency",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "title": "Error Rate & HTTP Status",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(kserve_predictor_request_duration_seconds_count{code!~\"2..\"}[1m])) by (code)",
          "legendFormat": "HTTP {{code}} errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "ops"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "title": "Resource Utilization (CPU & Memory)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(node_namespace_pod_container:container_cpu_usage_seconds_total:sum_irate{container=\"predictor\"}) by (pod)",
          "legendFormat": "{{pod}} CPU",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(container_memory_working_set_bytes{container=\"predictor\"}) by (pod) / 1024 / 1024",
          "legendFormat": "{{pod}} Memory (MiB)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "title": "Knative Autoscaling Replica Count",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(kube_deployment_status_replicas{deployment=~\"candidate-ranker.*\"}) by (deployment)",
          "legendFormat": "{{deployment}} active pods",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "step"
          },
          "unit": "short"
        }
      }
    }
